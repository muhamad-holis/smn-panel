# ==============================
# SUPABASE
# ==============================
# Ambil dari Project Settings > API di dashboard Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key HANYA dipakai di server (webhook, cron, admin). JANGAN taruh di NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==============================
# PROVIDER SMM (MedanPedia)
# ==============================
PROVIDER_API_URL=https://api.medanpedia.co.id
# Ambil di medanpedia.co.id/doc menu "Kredensial"
PROVIDER_API_ID=your-medanpedia-api-id
PROVIDER_API_KEY=your-medanpedia-api-key

# ==============================
# PAYMENT GATEWAY - CASHI.ID (satu-satunya gateway yang dipakai)
# ==============================
CASHI_API_URL=https://cashi.id/api
CASHI_API_KEY=your-cashi-id-api-key
# Ambil di Dashboard > Settings > API Keys (untuk hitung HMAC signature webhook)
CASHI_WEBHOOK_SECRET=your-cashi-webhook-secret
# true jika fitur QRIS Custom (nama toko sendiri) sudah diaktifkan di dashboard cashi.id
CASHI_USE_QRIS_CUSTOM=false

# ==============================
# APP
# ==============================
# Base URL production, dipakai untuk callback_url & redirect_url
NEXT_PUBLIC_APP_URL=https://panel-kamu.com
# Secret untuk melindungi endpoint cron (Vercel Cron akan mengirim header ini)
CRON_SECRET=ganti-dengan-random-string-panjang

# Markup harga default (%) yang diterapkan ke harga modal provider jika service baru disinkronkan
DEFAULT_MARKUP_PERCENT=30
